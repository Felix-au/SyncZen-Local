{
  "expo": {
    "name": "SyncStay",
    "slug": "syncstay-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "syncstay",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#060C17"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png"
      },
      "package": "com.syncstay.mobile",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE"
      ]
    },
    "plugins": [
      "expo-secure-store",
      "expo-status-bar",
      [
        "expo-camera",
        {
          "cameraPermission": "SyncStay needs camera access for guest photos and QR code scanning."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "SyncStay needs gallery access to attach document photos."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "ae7afe07-ca39-4c19-bf61-747369b0e7c7"
      }
    },
    "owner": "felixau"
  }
}
