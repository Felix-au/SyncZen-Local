{
  "name": "hotel-checkin-desktop",
  "version": "1.0.0",
  "description": "Hotel Check-In & Data Tracker — Desktop Overseer (Windows EXE)",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "tsc -p tsconfig.electron.json && concurrently -k \"tsc -p tsconfig.electron.json --watch\" \"vite\" \"node -e \\\"const net = require('net'); const check = () => { const s = net.createConnection(5173, 'localhost', () => { s.end(); process.exit(0); }); s.on('error', () => setTimeout(check, 200)); }; check();\\\" && electron .\"",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "package": "npm run build && electron-builder",
    "package:dir": "npm run build && electron-builder --dir",
    "clean": "if exist dist rmdir /s /q dist && if exist dist-electron rmdir /s /q dist-electron && if exist release rmdir /s /q release",
    "preview": "vite preview"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "jimp": "^0.22.12",
    "mariadb": "^3.3.1",
    "multer": "^1.4.5-lts.2",
    "qrcode": "^1.5.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.5",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^29.1.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vite-plugin-electron": "^0.28.4",
    "vite-plugin-electron-renderer": "^0.14.5",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.hotelcheckin.desktop",
    "productName": "Hotel Check-In",
    "copyright": "Copyright © 2026 Hotel Check-In",
    "directories": {
      "output": "release",
      "buildResources": "public"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "include": "installer.nsh",
      "artifactName": "HotelCheckIn-Setup-${version}.exe"
    },
    "extraResources": [
      {
        "from": "db-engine",
        "to": "db-engine",
        "filter": ["**/*", "!README.md", "!.gitkeep"]
      },
      {
        "from": "storage",
        "to": "storage",
        "filter": [".gitkeep"]
      }
    ]
  }
}
