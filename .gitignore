# Hotel Check-In & Data Tracker Gitignore

# 1. Workspace Rules
/scratch/
/scratch/*
.agentrules


# 2. Dependency Directories
node_modules/
jspm_packages/
web_modules/
mobile/.expo/
mobile/android/
mobile/ios/

# 3. Build & Target Output Directories
dist/
dist-electron/
build/
out/
obj/
release/
*.msi
*.zip
*.tar.gz

# Packaged binaries (but NOT source APKs tracked intentionally)
*.apk

# db-engine: ignore the actual binaries, keep README/.gitkeep
desktop/db-engine/bin/

# storage: ignore actual image uploads, keep .gitkeep
desktop/storage/portraits/
desktop/storage/id-proofs/

# 4. Embedded Database & Local Assets
*.db
*.sqlite
/db_data/
/assets/uploads/
mysql-data/
maria-data/
mobile/assets/*.png

# MariaDB runtime data directory (created at first launch in userData)
desktop/db-engine/data/

# 5. OS & IDE Configuration Files
.DS_Store
Thumbs.db
.idea/
.vscode/
*.suo
*.user
*.userosscache
*.sln.docstates
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 6. Log Files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log
